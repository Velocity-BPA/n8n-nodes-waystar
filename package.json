{
  "name": "n8n-nodes-waystar",
  "version": "1.0.0",
  "description": "Comprehensive n8n community node for Waystar healthcare revenue cycle management providing eligibility verification, claims processing, remittance handling, denial management, and complete RCM operations.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-waystar.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-waystar#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-waystar/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "waystar",
    "healthcare",
    "revenue-cycle-management",
    "rcm",
    "claims",
    "eligibility",
    "edi",
    "837",
    "835",
    "270",
    "271",
    "276",
    "277",
    "hipaa",
    "medical-billing",
    "remittance",
    "prior-authorization",
    "denial-management"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/WaystarApi.credentials.js",
      "dist/credentials/WaystarEdi.credentials.js",
      "dist/credentials/WaystarSftp.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Waystar/Waystar.node.js",
      "dist/nodes/Waystar/WaystarTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/ssh2-sftp-client": "^9.0.3",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "*",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "ssh2-sftp-client": "^9.1.0",
    "xml2js": "^0.6.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
